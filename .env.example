# Neon / Postgres — durable folder + file metadata (required for multi-device library)
# Create free DB: https://console.neon.tech → copy connection string
# Vercel: Project → Settings → Environment Variables → DATABASE_URL
DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# Required for real Shelby uploads (backend service wallet)
# Generate: aptos key generate  OR  use Petra export (testnet only)
APTOS_PRIVATE_KEY=0xYOUR_TESTNET_PRIVATE_KEY_HEX

# Network: testnet | shelbynet | local
APTOS_NETWORK=testnet

# Optional Shelby / Aptos API key
SHELBY_API_KEY=
# APTOS_API_KEY=

# Max encrypted payload bytes (default 10MB)
# MAX_UPLOAD_BYTES=10485760

# Browser (optional)
# VITE_APTOS_NETWORK=testnet
# VITE_SHELBY_API_KEY=
