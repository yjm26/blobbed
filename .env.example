# Neon / Postgres — durable folder + file metadata (required for multi-device library)
# Create free DB: https://console.neon.tech → copy connection string
# Vercel: Project → Settings → Environment Variables → DATABASE_URL
DATABASE_URL=postgresql://user:***@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# Required for real Shelby uploads — dedicated SERVICE wallet (not user Petra)
# Generate: node scripts/generate-service-wallet.mjs
# Fund APT + ShelbyUSD on shelbynet:
#   https://docs.shelby.xyz/tools/wallets/petra-setup
# Vercel → APTOS_PRIVATE_KEY + APTOS_NETWORK=shelbynet → Redeploy
APTOS_PRIVATE_KEY=0xYOUR_SHELBYNET_SERVICE_WALLET_PRIVATE_KEY_HEX

# Network for Shelby blob storage: shelbynet (recommended) | testnet | local
APTOS_NETWORK=shelbynet

# Optional browser download network (must match server)
# VITE_APTOS_NETWORK=shelbynet

# Optional: separate HMAC secret for library session tickets (defaults to APTOS_PRIVATE_KEY)
# LIBRARY_SESSION_SECRET=long-random-string

# Upload rate limit per owner address (default 30)
# UPLOAD_MAX_PER_HOUR=30
